# ── Database ───────────────────────────────────────────────────────────────
# Single consolidated database for all three apps. The app runs as a
# LEAST-PRIVILEGE account (CRUD only — no CREATE/DROP/GRANT). Run Prisma
# migrations with a separate, privileged DB account.
DATABASE_URL="postgresql://audit_app:CHANGE_ME@localhost:5432/audit_portal"

# ── JWT / Auth ─────────────────────────────────────────────────────────────
# 32+ byte random secret. Generate with: openssl rand -hex 32
JWT_ACCESS_SECRET="CHANGE_ME_access_secret"
ACCESS_TOKEN_TTL="15m"
REFRESH_TOKEN_TTL_DAYS="7"

# ── Bootstrap admin (seeded only if the users table is empty) ──────────────
DEFAULT_ADMIN_USER="admin"
DEFAULT_ADMIN_PASS="CHANGE_ME_strong_password"

# ── Server / CORS ──────────────────────────────────────────────────────────
PORT="3000"
NODE_ENV="development"
# Comma-separated allowlist (the Vite dev server default is 5173).
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"
# Cookie domain for the refresh-token cookie. Use your real domain in prod.
COOKIE_DOMAIN="localhost"
# Proxy hops to trust for the real client IP. "false" if the app is exposed
# directly; set to the exact number of proxies (e.g. "1") behind a load balancer.
# Wrong values let clients spoof X-Forwarded-For and bypass IP rate-limiting.
TRUST_PROXY="false"

# ── File uploads ───────────────────────────────────────────────────────────
# Resolved relative to the backend folder; kept OUTSIDE any served path.
UPLOAD_DIR="storage/uploads"
MAX_UPLOAD_MB="8"
